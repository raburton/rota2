@using Rota2.Models
@inject IUserService UserService
<BootstrapModal @ref="_modal" Title="Manage Leave" ConfirmText="Save" ShowCancel="true" OnConfirm="SaveChanges">
    <div class="mb-2">
        <button class="btn btn-sm btn-primary" @onclick="AddNew"><i class="bi bi-plus-lg me-1"></i>Add Leave</button>
    </div>
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-2">@_error</div>
    }
    <div class="mt-2">
        @if (_leaves == null || !_leaves.Any())
        {
            <div class="text-muted">No recorded leave.</div>
        }
        else
        {
            <table class="table table-sm">
                <thead><tr><th>Start</th><th>End</th><th>Notes</th><th></th></tr></thead>
                <tbody>
                    @foreach(var l in _leaves)
                    {
                        <tr>
                            <td>@l.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@l.EndDate.ToString("yyyy-MM-dd")</td>
                            <td>@l.Notes</td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="(() => Edit(l))"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="(() => Delete(l.Id))"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @if (_editing != null)
    {
        <div class="mt-3">
            <label class="form-label">Start</label>
            <InputDate class="form-control" @bind-Value="_editing.StartDate" />
            <label class="form-label mt-2">End</label>
            <InputDate class="form-control" @bind-Value="_editing.EndDate" />
            <label class="form-label mt-2">Notes</label>
            <InputTextArea class="form-control" @bind-Value="_editing.Notes" />
        </div>
    }
</BootstrapModal>

@code {
    private BootstrapModal? _modal;
    private IEnumerable<LeaveRequest>? _leaves;
    private LeaveRequest? _editing;
    private int _userId;
    private string _error = string.Empty;

    public async Task ShowAsync(int userId)
    {
        _userId = userId;
        await Load();
        if (_modal != null) await _modal.ShowAsync();
    }

    private async Task Load()
    {
        _leaves = UserService.GetLeavesForUser(_userId);
        _editing = null;
        _error = string.Empty;
    }

    private void AddNew()
    {
        _editing = new LeaveRequest { UserId = _userId, StartDate = DateTime.Today, EndDate = DateTime.Today };
    }

    private void Edit(LeaveRequest l)
    {
        _editing = new LeaveRequest { Id = l.Id, UserId = l.UserId, StartDate = l.StartDate, EndDate = l.EndDate, Notes = l.Notes };
    }

    private async Task Delete(int id)
    {
        UserService.DeleteLeave(id);
        await Load();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveChanges()
    {
        if (_editing == null) return;
        if (_editing.EndDate.Date < _editing.StartDate.Date)
        {
            _error = "End date must be the same or after start date.";
            return;
        }
        if (_editing.Id == 0)
        {
            UserService.CreateLeave(_editing);
        }
        else
        {
            UserService.UpdateLeave(_editing);
        }
        await Load();
        await Hide();
    }

    private async Task Hide()
    {
        if (_modal != null) await _modal.HideAsync();
    }
}
