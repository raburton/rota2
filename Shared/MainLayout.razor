@inherits LayoutComponentBase
@inject Rota2.Services.CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IRotaService RotaService
@using Rota2.Shared


<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Rota2</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
            <span class="navbar-toggler-icon"></span>
        </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <AuthorizeView>
                    <Authorized>
                        <li class="nav-item"><NavLink class="nav-link" href="/dashboard">Dashboard</NavLink></li>
                        <li class="nav-item"><NavLink class="nav-link" href="/calendar">Calendar</NavLink></li>
                    </Authorized>
                </AuthorizeView>
                @if (_showRotasLink)
                {
                    <li class="nav-item"><NavLink class="nav-link" href="/rotas">Rotas</NavLink></li>
                }
                @if (_showUsersLink)
                {
                    <li class="nav-item"><NavLink class="nav-link" href="/users">Users</NavLink></li>
                }
                @if (_showAllocationsLink)
                {
                    <li class="nav-item"><NavLink class="nav-link" href="/allocations">Allocations</NavLink></li>
                }
                @if (_showMyAllocationsLink)
                {
                    <li class="nav-item"><NavLink class="nav-link" href="/myshifts">My Shifts</NavLink></li>
                }
                @if (_showSwapsLink)
                {
                    <li class="nav-item"><NavLink class="nav-link" href="/swaps">Swaps</NavLink></li>
                }
            </ul>
            <div class="d-flex">
                <AuthorizeView>
                    <Authorized Context="state">
                        <div class="nav-item dropdown">
                            <a class="nav-link text-white" href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">@state.User.Identity?.Name <i class="bi bi-person-circle ms-2"></i></a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li><button class="dropdown-item" type="button" @onclick="OpenChangePassword">Change password</button></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><button class="dropdown-item" type="button" @onclick="Logout">Sign out</button></li>
                            </ul>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <NavLink class="nav-link text-white" href="@($"/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}")">Login</NavLink>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </div>
    <ChangePasswordModal @ref="_changePasswordModal" />
</nav>

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    @Body
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private HttpClient Http { get; set; } = default!;
    private ChangePasswordModal? _changePasswordModal;

    private bool _showRotasLink = false;
    private bool _showUsersLink = false;
    private bool _showAllocationsLink = false;
    private bool _showMyAllocationsLink = false;
    private bool _showSwapsLink = false;

    private Microsoft.AspNetCore.Components.Authorization.AuthenticationStateChangedHandler? _authStateHandler;

    protected override async Task OnInitializedAsync()
    {
        // initialize menu based on current auth state
        try
        {
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            await UpdateMenuForUser(state.User);
        }
        catch { }

        // subscribe to auth state changes so navbar updates when user logs in/out
        _authStateHandler = OnAuthenticationStateChanged;
        AuthStateProvider.AuthenticationStateChanged += _authStateHandler;
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        _ = HandleAuthStateChangedAsync(task);
    }

    private async Task HandleAuthStateChangedAsync(Task<AuthenticationState> task)
    {
        try
        {
            var st = await task;
            await UpdateMenuForUser(st.User);
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private Task UpdateMenuForUser(System.Security.Claims.ClaimsPrincipal user)
    {
        try
        {
            var isGlobal = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
            var role = user?.FindFirst(c => c.Type == "Role")?.Value;
            var currentUserId = 0;
            int.TryParse(user?.FindFirst(c => c.Type == "UserId")?.Value, out currentUserId);

            _showMyAllocationsLink = role == "Registrar" || role == "Consultant";
            _showSwapsLink = _showMyAllocationsLink;

            if (isGlobal)
            {
                _showRotasLink = true;
                _showUsersLink = true;
                _showAllocationsLink = true;
            }
            else
            {
                _showRotasLink = false;
                _showUsersLink = false;
                // check rota admin membership
                if (currentUserId > 0)
                {
                    var rotas = RotaService.GetAll();
                    var isRotaAdmin = rotas.Any(r => r.RotaAdmins.Any(ra => ra.UserId == currentUserId));
                    _showAllocationsLink = isRotaAdmin;
                }
                else
                {
                    _showAllocationsLink = false;
                }
            }
        }
        catch { }
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        if (_authStateHandler != null)
        {
            AuthStateProvider.AuthenticationStateChanged -= _authStateHandler;
            _authStateHandler = null;
        }
    }

    private async Task Logout()
    {
        try
        {
            var logoutUri = new Uri(new Uri(Nav.BaseUri), "account/logout").ToString();
            // use browser fetch via JS to ensure cookie is cleared in browser
            await JS.InvokeAsync<System.Text.Json.JsonElement>("postEmptyWithCredentials", logoutUri);
        }
        catch { }
        AuthStateProvider.MarkUserAsLoggedOut();
        await Task.Yield();
        Nav.NavigateTo("/login");
    }

    private async Task OpenChangePassword()
    {
        if (_changePasswordModal != null) await _changePasswordModal.ShowAsync();
    }
}
