@using Rota2.Models
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
<BootstrapModal @ref="_modal" Title="Change password" ConfirmText="Save" CancelText="Cancel" ShowCancel="true" OnConfirm="OnSave">
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    <div class="mb-2">
        <label class="form-label">Current password</label>
        <InputText type="password" class="form-control" @bind-Value="_current" />
    </div>
    <div class="mb-2">
        <label class="form-label">New password</label>
        <InputText type="password" class="form-control" @bind-Value="_new" />
    </div>
    <div class="mb-2">
        <label class="form-label">Confirm new password</label>
        <InputText type="password" class="form-control" @bind-Value="_confirm" />
    </div>
</BootstrapModal>

@code {
    private Shared.BootstrapModal? _modal;
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private string _error = string.Empty;

    public async Task ShowAsync()
    {
        _current = _new = _confirm = string.Empty;
        _error = string.Empty;
        await InvokeAsync(StateHasChanged);
        if (_modal != null) await _modal.ShowAsync();
    }

    private async Task OnSave()
    {
        _error = string.Empty;
        if (string.IsNullOrEmpty(_current) || string.IsNullOrEmpty(_new))
        {
            _error = "Please enter current and new passwords.";
            return;
        }
        if (_new != _confirm)
        {
            _error = "New passwords do not match.";
            return;
        }

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var email = user?.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value;
        var userIdStr = user?.FindFirst(c => c.Type == "UserId")?.Value;
        if (!int.TryParse(userIdStr, out var userId) || string.IsNullOrEmpty(email))
        {
            _error = "Unable to determine current user.";
            return;
        }

        var auth = UserService.Authenticate(email, _current);
        if (auth == null || auth.Id != userId)
        {
            _error = "Current password is incorrect.";
            return;
        }

        UserService.UpdatePassword(userId, _new);
        if (_modal != null) await _modal.HideAsync();
    }
}
