@page "/"
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <div class="card">
            <div class="card-body">
                <h3>Welcome</h3>
                <p>You are logged in.</p>
                <ActionButton Icon="bi-speedometer2" Text="Admin Dashboard" Variant="btn-primary" Href="/admin" />
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="card">
            <div class="card-body">
                <h3>Welcome</h3>
                <p>Please <NavLink href="/login">login</NavLink>.</p>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
