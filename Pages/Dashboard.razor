@page "/dashboard"
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IRotaService RotaService

<h3>Dashboard</h3>

@if (_isGlobalAdmin || _isRotaAdmin)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>Admin</h5>
            <div class="mb-3 d-flex">
                @if (_isGlobalAdmin)
                {
                    <ActionButton Icon="bi-calendar2-week" Text="@($"Manage Rotas ({_rotasCount ?? 0})")" Variant="btn-primary" Href="/rotas" />
                    <ActionButton Icon="bi-people" Text="@($"Manage Users ({_activeUsersCount ?? 0})")" Variant="btn-primary ms-2" Href="/users" />
                    <ActionButton Icon="bi-diagram-3" Text="Shift Allocations" Variant="btn-primary ms-2" Href="/allocations" />
                }
                else if (_isRotaAdmin)
                {
                    <ActionButton Icon="bi-diagram-3" Text="Shift Allocations" Variant="btn-primary" Href="/allocations" />
                }
            </div>
        </div>
    </div>
}

@* Doctor panel for registrars/consultants *@
@if (_isDoctorRole)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5>Doctors</h5>
            <p class="mb-2">Doctor tools for registrars and consultants.</p>
                <div class="d-flex">
                <ActionButton Icon="bi-calendar-check" Text="My Shifts" Variant="btn-primary" Href="/myshifts" />
                <ActionButton Icon="bi-calendar-x" Text="Manage Leave" Variant="btn-primary ms-2" OnClick="@OpenLeaveManager" />
            </div>
        </div>
    </div>
}

<LeaveManager @ref="_leaveManager" />

@code {
    private bool _isGlobalAdmin = false;
    private int? _rotasCount = null;
    private int? _activeUsersCount = null;
    private bool _isRotaAdmin = false;
    private Shared.LeaveManager? _leaveManager;
    private int _currentUserId = 0;
    private bool _isDoctorRole = false;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        var role = user?.FindFirst(c => c.Type == "Role")?.Value;
        _isDoctorRole = role == "Registrar" || role == "Consultant";
        if (int.TryParse(user?.FindFirst(c => c.Type == "UserId")?.Value, out var uid)) _currentUserId = uid;
        if (_isGlobalAdmin)
        {
            _rotasCount = RotaService.GetAll().Count();
            _activeUsersCount = UserService.GetAllUsers().Count(u => u.Active);
        }
        // also show admin card for rota admins (even if not global)
        if (!_isGlobalAdmin && _currentUserId > 0)
        {
            var rotas = RotaService.GetAll();
            _isRotaAdmin = rotas.Any(r => r.RotaAdmins.Any(ra => ra.UserId == _currentUserId));
            if (_isRotaAdmin)
            {
                _rotasCount = rotas.Count();
            }
        }
    }

    private async Task OpenLeaveManager()
    {
        if (_leaveManager != null)
        {
            await _leaveManager.ShowAsync(_currentUserId);
        }
    }

}
