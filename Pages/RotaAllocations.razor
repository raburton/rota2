@page "/rotas/allocations"
@using Rota2.Models
@inject IRotaService RotaService
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>Rota Allocations</h3>

@if (!_isGlobalAdmin)
{
    <div class="alert alert-danger">Not authorized.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>Create allocations</h5>
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Rota</label>
                    <select class="form-select" @bind="_selectedRotaId">
                        <option value="0">-- select rota --</option>
                        @foreach(var r in _rotas ?? Enumerable.Empty<Rota>())
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start date</label>
                    <InputDate class="form-control" @bind-Value="_startDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End date</label>
                    <InputDate class="form-control" @bind-Value="_endDate" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="Allocate"><i class="bi bi-calendar-plus me-1"></i>Allocate</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Create/view assignments table (shows assignments related to actions above) -->
    @if (_assignments != null)
    {
        <div class="mb-2">
            <button class="btn btn-secondary" @onclick="Refresh"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
        </div>
        <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>Date</th><th>Shift</th><th>Time</th><th>Doctor</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach(var a in _assignments)
            {
                <tr>
                    <td>@a.Date.ToString("yyyy-MM-dd")</td>
                    <td>@a.Shift?.Day</td>
                    <td>@a.Shift?.Start.ToString("hh\\:mm") - @a.Shift?.End.ToString("hh\\:mm")</td>
                    <td>@(a.User?.Name ?? "(none)")</td>
                    <td>
                        <ActionButton Icon="bi-person-circle" Text="Allocate" Variant="btn-outline-secondary" Size="btn-sm" OnClick="@(async () => await OpenDoctorPicker(a.Id, a.UserId, false))" />
                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="(() => ClearAssignment(a.Id))"><i class="bi bi-x-lg"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }

    <DoctorPicker @ref="_doctorPicker" />

    <BootstrapModal @ref="_confirmOverwriteModal" Title="Overwrite assignments?" ConfirmText="Continue" CancelText="Cancel" ShowCancel="true" OnConfirm="ConfirmOverwrite">
        <p>Existing assignments were found for the selected rota and date range. Creating new assignments will override them. Do you want to continue?</p>
        <p class="text-muted">Rota: @(_rotas?.FirstOrDefault(r => r.Id == _pendingRotaId)?.Name ?? "(unknown)")<br />From: @_pendingStart.ToString("yyyy-MM-dd") To: @_pendingEnd.ToString("yyyy-MM-dd")</p>
    </BootstrapModal>

    <!-- Separate view: show allocations for selected rota/date range (defaults to current month, no rota selected) -->
    <div class="card mt-4 p-3">
        <h5>Show allocations</h5>
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Rota</label>
                <select class="form-select" @bind="_viewRotaId">
                    <option value="0">-- select rota --</option>
                    @foreach(var r in _rotas ?? Enumerable.Empty<Rota>())
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Start date</label>
                <InputDate class="form-control" @bind-Value="_viewStartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End date</label>
                <InputDate class="form-control" @bind-Value="_viewEndDate" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary" @onclick="LoadViewAssignments">Show</button>
            </div>
        </div>

        @if (_viewRotaId == 0)
        {
            <div class="mt-3 text-muted">Select a rota to see allocations.</div>
        }
        else if (_viewAssignments == null || !_viewAssignments.Any())
        {
            <div class="mt-3">No allocations found for the selected period.</div>
        }
        else
        {
            <table class="table mt-3">
                <thead><tr><th>Date</th><th>Shift</th><th>Time</th><th>Doctor</th><th>Actions</th></tr></thead>
                <tbody>
                @foreach(var a in _viewAssignments)
                {
                    <tr>
                        <td>@a.Date.ToString("yyyy-MM-dd")</td>
                        <td>@a.Shift?.Day</td>
                        <td>@a.Shift?.Start.ToString("hh\\:mm") - @a.Shift?.End.ToString("hh\\:mm")</td>
                        <td>@(a.User?.Name ?? "(none)")</td>
                        <td>
                            <ActionButton Icon="bi-person-circle" Text="Allocate" Variant="btn-outline-secondary" Size="btn-sm" OnClick="@(async () => await OpenDoctorPicker(a.Id, a.UserId, true))" />
                            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="(() => ClearViewAssignment(a.Id))">Clear</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>

            @* Analysis section: per-doctor WTE, assigned count, and target for the selected rota/time period *@
            <div class="card mt-3">
                <div class="card-body">
                    <h5>Allocation analysis</h5>
                    @if (_analysis == null)
                    {
                        <p class="text-muted">No analysis available.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead><tr><th>Doctor</th><th>WTE</th><th>Allocated</th><th>Target</th><th>Diff</th></tr></thead>
                                <tbody>
                                @foreach(var r in _analysis)
                                {
                                    <tr>
                                        <td>@r.Name</td>
                                        <td>@(double.IsNaN(r.Wte) ? string.Empty : r.Wte.ToString("0.##"))</td>
                                        <td>@r.Assigned</td>
                                        <td>@r.Target.ToString("0.##")</td>
                                        <td>@((r.Assigned - r.Target).ToString("0.##"))</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private IEnumerable<Rota>? _rotas;
    private IEnumerable<Rota2.Models.ShiftAssignment>? _assignments;
    private List<Rota2.Models.User> _doctors = new List<Rota2.Models.User>();
    private bool _isGlobalAdmin = false;
    private int _selectedRotaId = 0;
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate = DateTime.Today.AddDays(7);
    // view filters (separate from create controls)
    private int _viewRotaId = 0;
    private DateTime _viewStartDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _viewEndDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1).AddDays(-1);
    private IEnumerable<Rota2.Models.ShiftAssignment>? _viewAssignments;
    private List<AnalysisRow>? _analysis;
    private Shared.DoctorPicker? _doctorPicker;
    private int _editingAssignmentId = 0;
    private bool _editingIsView = false;
    private Shared.BootstrapModal? _confirmOverwriteModal;
    private int _pendingRotaId = 0;
    private DateTime _pendingStart;
    private DateTime _pendingEnd;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (!_isGlobalAdmin) return;
        _rotas = RotaService.GetAll();
        _doctors = UserService.GetAllUsers().Where(u => u.Role == UserRole.Registrar || u.Role == UserRole.Consultant).ToList();
    }

    private void Allocate()
    {
        if (_selectedRotaId == 0) return;
        var start = _startDate.Date;
        var end = _endDate.Date;
        if (end < start) return;
        // check for existing assignments in range
        var existing = RotaService.GetAssignments(_selectedRotaId, start, end);
        if (existing != null && existing.Any())
        {
            // prompt user for confirmation since this will override existing assignments
            _pendingRotaId = _selectedRotaId;
            _pendingStart = start;
            _pendingEnd = end;
            _ = InvokeAsync(async () => { if (_confirmOverwriteModal != null) await _confirmOverwriteModal.ShowAsync(); });
            return;
        }

        // no existing assignments - create directly
        RotaService.CreateAssignments(_selectedRotaId, start, end);
        // after creating, set view filters to the newly created range and rota
        _viewRotaId = _selectedRotaId;
        _viewStartDate = start;
        _viewEndDate = end;
        LoadViewAssignments();
    }

    private async Task ConfirmOverwrite()
    {
        // perform creation using pending values
        if (_pendingRotaId == 0) return;
        RotaService.CreateAssignments(_pendingRotaId, _pendingStart, _pendingEnd);
        // update view filters
        _viewRotaId = _pendingRotaId;
        _viewStartDate = _pendingStart;
        _viewEndDate = _pendingEnd;
        LoadViewAssignments();
        if (_confirmOverwriteModal != null) await _confirmOverwriteModal.HideAsync();
    }

    private void LoadAssignments()
    {
        if (_selectedRotaId == 0) return;
        var start = _startDate.Date;
        var end = _endDate.Date;
        _assignments = RotaService.GetAssignments(_selectedRotaId, start, end);
    }

    private void LoadViewAssignments()
    {
        if (_viewRotaId == 0) { _viewAssignments = null; return; }
        var start = _viewStartDate.Date;
        var end = _viewEndDate.Date;
        _viewAssignments = RotaService.GetAssignments(_viewRotaId, start, end);
        ComputeAnalysis(_viewRotaId, start, end);
    }

    private void ComputeAnalysis(int rotaId, DateTime start, DateTime end)
    {
        _analysis = new List<AnalysisRow>();
        var rota = RotaService.GetById(rotaId);
        if (rota == null) return;
        // determine actual number of shift slots that exist in the database for this rota and period
        // prefer using the view assignments (these represent slots that were created/allocated)
        var slots = (_viewAssignments ?? Enumerable.Empty<Rota2.Models.ShiftAssignment>()).Count();
        // fallback: if there are no assignments in the DB for this range, fall back to counting theoretical slots
        if (slots == 0)
        {
            for (var d = start.Date; d <= end.Date; d = d.AddDays(1))
            {
                foreach (var s in rota.Shifts)
                {
                    if (s.Day == d.DayOfWeek) slots++;
                }
            }
        }

        // only consider active doctors for targets
        var doctors = rota.RotaDoctors.Select(rd => rd.User).Where(u => u != null && u.Active).ToList();
        var totalWte = doctors.Sum(d => (double)(d?.Wte ?? 1.0m));

        // count assigned per doctor in view assignments (separating unallocated/null keys)
        var assignmentsList = (_viewAssignments ?? Enumerable.Empty<Rota2.Models.ShiftAssignment>()).ToList();
        var unallocated = assignmentsList.Count(a => a.UserId == null);
        var counts = assignmentsList.Where(a => a.UserId != null).GroupBy(a => a.UserId!.Value).ToDictionary(g => g.Key, g => g.Count());
        _analysis.Add(new AnalysisRow { UserId = 0, Name = "(Unallocated)", Wte = double.NaN, Assigned = unallocated, Target = 0.0 });

        foreach (var doc in doctors)
        {
            var uid = doc!.Id;
            var wte = (double)doc.Wte;
            var assigned = counts.ContainsKey(uid) ? counts[uid] : 0;
            var target = totalWte > 0 ? slots * (wte / totalWte) : 0.0;
            _analysis.Add(new AnalysisRow { UserId = uid, Name = doc.Name, Wte = wte, Assigned = assigned, Target = target });
        }
    }

    private class AnalysisRow { public int UserId { get; set; } public string Name { get; set; } = string.Empty; public double Wte { get; set; } public int Assigned { get; set; } public double Target { get; set; } }

    private void Refresh() => LoadAssignments();

    private void Assign(int assignmentId, int? userId)
    {
        RotaService.UpdateAssignment(assignmentId, userId);
        LoadAssignments();
    }

    private async Task OpenDoctorPicker(int assignmentId, int? currentUserId, bool isView)
    {
        _editingAssignmentId = assignmentId;
        _editingIsView = isView;
        if (_doctorPicker != null)
        {
            var chosen = await _doctorPicker.ShowAsync(_doctors, currentUserId);
            if (chosen.HasValue)
            {
                if (isView) AssignView(assignmentId, chosen.Value); else Assign(assignmentId, chosen.Value);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void ClearAssignment(int assignmentId)
    {
        RotaService.UpdateAssignment(assignmentId, null);
        LoadAssignments();
    }

    private void AssignView(int assignmentId, int? userId)
    {
        RotaService.UpdateAssignment(assignmentId, userId);
        LoadViewAssignments();
    }

    private void ClearViewAssignment(int assignmentId)
    {
        RotaService.UpdateAssignment(assignmentId, null);
        LoadViewAssignments();
    }
}
