@page "/rotas/allocations"
@using Rota2.Models
@inject IRotaService RotaService
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>Rota Allocations</h3>

@if (!_isGlobalAdmin)
{
    <div class="alert alert-danger">Not authorized.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">Rota</label>
                    <select class="form-select" @bind="_selectedRotaId">
                        <option value="0">-- select rota --</option>
                        @foreach(var r in _rotas ?? Enumerable.Empty<Rota>())
                        {
                            <option value="@r.Id">@r.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start date</label>
                    <InputDate class="form-control" @bind-Value="_startDate" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End date</label>
                    <InputDate class="form-control" @bind-Value="_endDate" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="Allocate"><i class="bi bi-calendar-plus me-1"></i>Allocate</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Create/view assignments table (shows assignments related to actions above) -->
    @if (_assignments != null)
    {
        <div class="mb-2">
            <button class="btn btn-secondary" @onclick="Refresh"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
        </div>
        <div class="table-responsive">
        <table class="table table-sm table-striped align-middle">
            <thead><tr><th>Date</th><th>Shift</th><th>Time</th><th>Doctor</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach(var a in _assignments)
            {
                <tr>
                    <td>@a.Date.ToString("yyyy-MM-dd")</td>
                    <td>@a.Shift?.Day</td>
                    <td>@a.Shift?.Start.ToString("hh\\:mm") - @a.Shift?.End.ToString("hh\\:mm")</td>
                    <td>@(a.User?.Name ?? "(none)")</td>
                    <td>
                        <ActionButton Icon="bi-person-circle" Text="Allocate" Variant="btn-outline-secondary" Size="btn-sm" OnClick="@(async () => await OpenDoctorPicker(a.Id, a.UserId, false))" />
                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="(() => ClearAssignment(a.Id))"><i class="bi bi-x-lg"></i></button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }

    <DoctorPicker @ref="_doctorPicker" />

    <!-- Separate view: show allocations for selected rota/date range (defaults to current month, no rota selected) -->
    <div class="card mt-4 p-3">
        <h5>Show allocations</h5>
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Rota</label>
                <select class="form-select" @bind="_viewRotaId">
                    <option value="0">-- select rota --</option>
                    @foreach(var r in _rotas ?? Enumerable.Empty<Rota>())
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Start date</label>
                <InputDate class="form-control" @bind-Value="_viewStartDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">End date</label>
                <InputDate class="form-control" @bind-Value="_viewEndDate" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary" @onclick="LoadViewAssignments">Show</button>
            </div>
        </div>

        @if (_viewRotaId == 0)
        {
            <div class="mt-3 text-muted">Select a rota to see allocations.</div>
        }
        else if (_viewAssignments == null || !_viewAssignments.Any())
        {
            <div class="mt-3">No allocations found for the selected period.</div>
        }
        else
        {
            <table class="table mt-3">
                <thead><tr><th>Date</th><th>Shift</th><th>Time</th><th>Doctor</th><th>Actions</th></tr></thead>
                <tbody>
                @foreach(var a in _viewAssignments)
                {
                    <tr>
                        <td>@a.Date.ToString("yyyy-MM-dd")</td>
                        <td>@a.Shift?.Day</td>
                        <td>@a.Shift?.Start.ToString("hh\\:mm") - @a.Shift?.End.ToString("hh\\:mm")</td>
                        <td>@(a.User?.Name ?? "(none)")</td>
                        <td>
                            <ActionButton Icon="bi-person-circle" Text="Allocate" Variant="btn-outline-secondary" Size="btn-sm" OnClick="@(async () => await OpenDoctorPicker(a.Id, a.UserId, true))" />
                            <button class="btn btn-sm btn-outline-danger ms-2" @onclick="(() => ClearViewAssignment(a.Id))">Clear</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
}

@code {
    private IEnumerable<Rota>? _rotas;
    private IEnumerable<Rota2.Models.ShiftAssignment>? _assignments;
    private List<Rota2.Models.User> _doctors = new List<Rota2.Models.User>();
    private bool _isGlobalAdmin = false;
    private int _selectedRotaId = 0;
    private DateTime _startDate = DateTime.Today;
    private DateTime _endDate = DateTime.Today.AddDays(7);
    // view filters (separate from create controls)
    private int _viewRotaId = 0;
    private DateTime _viewStartDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _viewEndDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1).AddDays(-1);
    private IEnumerable<Rota2.Models.ShiftAssignment>? _viewAssignments;
    private Shared.DoctorPicker? _doctorPicker;
    private int _editingAssignmentId = 0;
    private bool _editingIsView = false;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (!_isGlobalAdmin) return;
        _rotas = RotaService.GetAll();
        _doctors = UserService.GetAllUsers().Where(u => u.Role == UserRole.Registrar || u.Role == UserRole.Consultant).ToList();
    }

    private void Allocate()
    {
        if (_selectedRotaId == 0) return;
        var start = _startDate.Date;
        var end = _endDate.Date;
        if (end < start) return;
        RotaService.CreateAssignments(_selectedRotaId, start, end);
        // after creating, set view filters to the newly created range and rota
        _viewRotaId = _selectedRotaId;
        _viewStartDate = start;
        _viewEndDate = end;
        LoadViewAssignments();
    }

    private void LoadAssignments()
    {
        if (_selectedRotaId == 0) return;
        var start = _startDate.Date;
        var end = _endDate.Date;
        _assignments = RotaService.GetAssignments(_selectedRotaId, start, end);
    }

    private void LoadViewAssignments()
    {
        if (_viewRotaId == 0) { _viewAssignments = null; return; }
        var start = _viewStartDate.Date;
        var end = _viewEndDate.Date;
        _viewAssignments = RotaService.GetAssignments(_viewRotaId, start, end);
    }

    private void Refresh() => LoadAssignments();

    private void Assign(int assignmentId, int? userId)
    {
        RotaService.UpdateAssignment(assignmentId, userId);
        LoadAssignments();
    }

    private async Task OpenDoctorPicker(int assignmentId, int? currentUserId, bool isView)
    {
        _editingAssignmentId = assignmentId;
        _editingIsView = isView;
        if (_doctorPicker != null)
        {
            var chosen = await _doctorPicker.ShowAsync(_doctors, currentUserId);
            if (chosen.HasValue)
            {
                if (isView) AssignView(assignmentId, chosen.Value); else Assign(assignmentId, chosen.Value);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void ClearAssignment(int assignmentId)
    {
        RotaService.UpdateAssignment(assignmentId, null);
        LoadAssignments();
    }

    private void AssignView(int assignmentId, int? userId)
    {
        RotaService.UpdateAssignment(assignmentId, userId);
        LoadViewAssignments();
    }

    private void ClearViewAssignment(int assignmentId)
    {
        RotaService.UpdateAssignment(assignmentId, null);
        LoadViewAssignments();
    }
}
