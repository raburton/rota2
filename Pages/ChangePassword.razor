@page "/changepassword"
@using System.Security.Claims
@inject Rota2.Services.IUserService UserService
@inject NavigationManager Nav
@attribute [Authorize]

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-3">Change Password</h4>

                @if (!string.IsNullOrEmpty(_message))
                {
                    <div class="alert alert-info">@_message</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleChange">
                    <div class="mb-3">
                        <label class="form-label">Current password</label>
                        <InputText @bind-Value="_model.CurrentPassword" type="password" class="form-control" placeholder="Current password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">New password</label>
                        <InputText @bind-Value="_model.NewPassword" type="password" class="form-control" placeholder="New password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm new password</label>
                        <InputText @bind-Value="_model.ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                    </div>
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-primary" type="submit">Change Password</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private ChangeModel _model = new ChangeModel();
    private string _message = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private async Task HandleChange()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        if (user?.Identity == null || !user.Identity.IsAuthenticated)
        {
            _message = "Not authenticated.";
            Nav.NavigateTo("/login");
            return;
        }

        var email = user.FindFirst(c => c.Type == ClaimTypes.Email)?.Value;
        var idClaim = user.FindFirst(c => c.Type == "UserId")?.Value;
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(idClaim))
        {
            _message = "Unable to determine user.";
            return;
        }

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _message = "New password and confirmation do not match.";
            return;
        }

        var auth = UserService.Authenticate(email, _model.CurrentPassword);
        if (auth == null)
        {
            _message = "Current password is incorrect.";
            return;
        }

        if (!int.TryParse(idClaim, out var id))
        {
            _message = "Invalid user id.";
            return;
        }

        UserService.UpdatePassword(id, _model.NewPassword);
        _message = "Password changed.";
        Nav.NavigateTo("/");
    }

    private class ChangeModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
