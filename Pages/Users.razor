@page "/users"
@using Rota2.Services
@using Microsoft.AspNetCore.Components.Forms
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IUserService UserService
@inject Rota2.Services.IEmailService EmailService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<h3>User Management</h3>

@if (!_isGlobalAdmin)
{
    <div class="alert alert-danger">You are not authorized to manage users.</div>
}
else if (_users == null)
{
    <p>Loading...</p>
}
else
{
    <div class="row mb-2">
        <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-primary" @onclick="AddUser"><i class="bi bi-plus-lg me-1"></i>Add User</button>
            <button class="btn btn-primary ms-2" @onclick="OpenImportModal"><i class="bi bi-upload me-1"></i>Import CSV</button>
        </div>
    </div>

    <div class="row g-2 mb-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label">Status</label>
            <select class="form-select" @bind="_statusFilter">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
                <option value="All">All</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Role</label>
            <select class="form-select" @bind="_roleFilter">
                <option value="All">All</option>
                @foreach(var r in Enum.GetValues(typeof(Rota2.Models.UserRole)).Cast<Rota2.Models.UserRole>())
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" id="adminOnly" @bind="_adminOnly" />
                <label class="form-check-label" for="adminOnly">Admins only</label>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input class="form-control" @bind="_search" placeholder="Search name" />
        </div>
        
    </div>

    <BootstrapModal @ref="_importModal" Title="Import users from CSV" DisableBackdropClose="true">
        <ChildContent>
            <div class="mb-2">
                <label class="form-label">CSV file (email,name,role,wte)</label>
                <InputFile @key="_importFileKey" OnChange="OnImportFileSelected" accept=".csv" />
            </div>
            @if (_importErrors.Any())
            {
                <div class="alert alert-danger">
                    <strong>Errors:</strong>
                    <ul>
                    @foreach(var err in _importErrors)
                    {
                        <li>@err</li>
                    }
                    </ul>
                </div>
            }
            @if (_importPreview.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead><tr><th>Email</th><th>Name</th><th>Role</th><th>WTE</th><th>Status</th></tr></thead>
                        <tbody>
                        @foreach(var row in _importPreview)
                        {
                            <tr>
                                <td>@row.Email</td>
                                <td>@row.Name</td>
                                <td>@row.RoleText</td>
                                <td>@row.WteText</td>
                                <td>@(row.IsValid ? "OK" : row.Error)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </ChildContent>
        <Footer>
            <button class="btn btn-secondary" type="button" @onclick="CloseImportModal">Cancel</button>
            <button class="btn btn-primary ms-2" type="button" @onclick="ConfirmImport" disabled="@(!_importPreview.Any() || _importErrors.Any())">Import</button>
        </Footer>
    </BootstrapModal>

    <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.Name))" style="cursor:pointer">Name @SortIcon(nameof(Rota2.Models.User.Name))</th>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.Email))" style="cursor:pointer">Email @SortIcon(nameof(Rota2.Models.User.Email))</th>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.Role))" style="cursor:pointer">Role @SortIcon(nameof(Rota2.Models.User.Role))</th>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.Wte))" style="cursor:pointer">WTE @SortIcon(nameof(Rota2.Models.User.Wte))</th>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.Active))" style="cursor:pointer">Active @SortIcon(nameof(Rota2.Models.User.Active))</th>
                <th @onclick="() => SetSort(nameof(Rota2.Models.User.IsGlobalAdmin))" style="cursor:pointer">Admin @SortIcon(nameof(Rota2.Models.User.IsGlobalAdmin))</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach(var u in DisplayUsers)
        {
            <tr>
                <td>@u.Name</td>
                <td>@u.Email</td>
                <td>@u.Role</td>
                <td>@u.Wte</td>
                <td>
                    @if (u.Active)
                    {
                        <i class="bi bi-check-lg text-success" title="Active"></i>
                    }
                    else
                    {
                        <i class="bi bi-x-lg text-danger" title="Inactive"></i>
                    }
                </td>
                <td>
                    @if (u.IsGlobalAdmin)
                    {
                        <i class="bi bi-shield-lock-fill text-primary" title="Global admin"></i>
                    }
                    else
                    {
                        <i class="bi bi-shield text-muted" title="Not admin"></i>
                    }
                </td>
                <td>
                    <ActionButton Icon="bi-pencil-square" Text="Edit" Variant="btn-outline-primary" Size="btn-sm" Href="@($"/users/edit/{u.Id}")" />
                    @if (u.Active)
                    {
                        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => ToggleActive(u.Id)"><i class="bi bi-person-x me-1"></i>Deactivate</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-success ms-2" @onclick="() => ToggleActive(u.Id)"><i class="bi bi-person-check me-1"></i>Reactivate</button>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
    </div>
}

@code {
    private IEnumerable<Rota2.Models.User>? _users;
    private bool _isGlobalAdmin = false;
    private string _statusFilter { get; set; } = "Active"; // Active, Inactive, All
    private string _roleFilter { get; set; } = "All";
    private bool _adminOnly { get; set; } = false;
    private string _search { get; set; } = string.Empty;
    private string _sortColumn { get; set; } = nameof(Rota2.Models.User.Name);
    private bool _sortAsc { get; set; } = true;

    private IEnumerable<Rota2.Models.User> DisplayUsers =>
        (_users ?? Enumerable.Empty<Rota2.Models.User>())
            .Where(u => _statusFilter == "All" ? true : (_statusFilter == "Active" ? u.Active : !u.Active))
            .Where(u => _adminOnly ? u.IsGlobalAdmin : true)
            .Where(u => _roleFilter == "All" ? true : u.Role.ToString() == _roleFilter)
            .Where(u => string.IsNullOrWhiteSpace(_search) ? true : u.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))
            .OrderByDynamic(_sortColumn, _sortAsc)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (_isGlobalAdmin)
        {
            _users = UserService.GetAllUsers();
        }
    }

    private void AddUser()
    {
        Nav.NavigateTo("/users/edit");
    }

    private string _importMessage = string.Empty;
    private Shared.BootstrapModal? _importModal;
    private List<ImportRow> _importPreview = new();
    private List<string> _importErrors = new();
    private IBrowserFile? _selectedImportFile;
    private int _importFileKey = 0;

    private void OpenImportModal()
    {
        _importPreview.Clear();
        _importErrors.Clear();
        _selectedImportFile = null;
        _importFileKey++; // reset InputFile component
        _ = _importModal?.ShowAsync();
    }

    private async Task CloseImportModal()
    {
        _importPreview.Clear();
        _importErrors.Clear();
        _selectedImportFile = null;
        _importFileKey++; // reset InputFile component
        if (_importModal != null) await _importModal.HideAsync();
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs e)
    {
        _importPreview.Clear();
        _importErrors.Clear();
        _selectedImportFile = e.File;
        if (_selectedImportFile == null) return;
        try
        {
            using var stream = _selectedImportFile.OpenReadStream(10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            // read entire file asynchronously to avoid synchronous read on the underlying stream
            var content = await reader.ReadToEndAsync();
            var lines = content.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries).ToList();
            int rowIndex = 0;
            foreach (var raw in lines)
            {
                rowIndex++;
                var line = raw.Trim();
                if (string.IsNullOrWhiteSpace(line)) continue;
                // skip header if detected
                if (rowIndex == 1 && line.IndexOf("email", StringComparison.OrdinalIgnoreCase) >= 0 && line.IndexOf("name", StringComparison.OrdinalIgnoreCase) >= 0)
                {
                    continue;
                }
                var fields = ParseCsvLine(line).ToArray();
                if (fields.Length == 0) continue;
                var email = fields.Length > 0 ? fields[0].Trim() : string.Empty;
                var name = fields.Length > 1 ? fields[1].Trim() : string.Empty;
                var roleText = fields.Length > 2 ? fields[2].Trim() : string.Empty;
                var wteText = fields.Length > 3 ? fields[3].Trim() : string.Empty;
                var row = new ImportRow { Email = email, Name = name, RoleText = roleText, WteText = wteText };
                // validate
                if (string.IsNullOrWhiteSpace(email)) { row.IsValid = false; row.Error = "Missing email"; _importErrors.Add($"Line {rowIndex}: missing email"); }
                if (!string.IsNullOrWhiteSpace(roleText) && !Enum.TryParse<Rota2.Models.UserRole>(roleText, true, out var pr)) { row.IsValid = false; row.Error = row.Error == null ? "Invalid role" : row.Error + "; invalid role"; _importErrors.Add($"Line {rowIndex}: invalid role '{roleText}'"); }
                if (!string.IsNullOrWhiteSpace(wteText) && !decimal.TryParse(wteText, out var pw)) { row.IsValid = false; row.Error = row.Error == null ? "Invalid WTE" : row.Error + "; invalid WTE"; _importErrors.Add($"Line {rowIndex}: invalid wte '{wteText}'"); }
                _importPreview.Add(row);
            }
        }
        catch (Exception ex)
        {
            _importErrors.Add("Failed to read file: " + ex.Message);
        }
        await InvokeAsync(StateHasChanged);
    }

    private IEnumerable<string> ParseCsvLine(string line)
    {
        var fields = new List<string>();
        var sb = new System.Text.StringBuilder();
        bool inQuotes = false;
        for (int i = 0; i < line.Length; i++)
        {
            var c = line[i];
            if (c == '"')
            {
                if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                {
                    // escaped quote
                    sb.Append('"');
                    i++; // skip next
                }
                else
                {
                    inQuotes = !inQuotes;
                }
            }
            else if (c == ',' && !inQuotes)
            {
                fields.Add(sb.ToString());
                sb.Clear();
            }
            else
            {
                sb.Append(c);
            }
        }
        fields.Add(sb.ToString());
        return fields;
    }

    private async Task ConfirmImport()
    {
        if (!_importPreview.Any()) return;
        int created = 0, updated = 0;
        var allUsers = UserService.GetAllUsers().ToList();
        foreach (var row in _importPreview)
        {
            if (!row.IsValid) continue;
            var role = Rota2.Models.UserRole.None;
            if (!string.IsNullOrWhiteSpace(row.RoleText) && Enum.TryParse<Rota2.Models.UserRole>(row.RoleText, true, out var parsedRole)) role = parsedRole;
            decimal wte = 1.0m;
            if (!string.IsNullOrWhiteSpace(row.WteText) && decimal.TryParse(row.WteText, out var parsedWte)) wte = parsedWte;
            var existing = allUsers.FirstOrDefault(u => u.Email.Equals(row.Email, StringComparison.OrdinalIgnoreCase));
            if (existing != null)
            {
                existing.Name = string.IsNullOrEmpty(row.Name) ? existing.Name : row.Name;
                existing.Role = role;
                existing.Wte = wte;
                UserService.UpdateUser(existing);
                updated++;
            }
            else
            {
                var nu = new Rota2.Models.User
                {
                    Email = row.Email,
                    Name = string.IsNullOrEmpty(row.Name) ? row.Email : row.Name,
                    Role = role,
                    Wte = wte,
                    Active = true,
                    IsGlobalAdmin = false
                };
                UserService.CreateUserNoPassword(nu);
                // send notification (best-effort)
                try { await EmailService.SendNewUserNotificationAsync(nu.Email, nu.Name); } catch { }
                created++;
            }
        }
        _users = UserService.GetAllUsers();
        _importMessage = $"Imported: {created} created, {updated} updated.";
        _importPreview.Clear(); _importErrors.Clear();
        if (_importModal != null) await _importModal.HideAsync();
        await InvokeAsync(StateHasChanged);
    }

    private class ImportRow
    {
        public string Email { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string RoleText { get; set; } = string.Empty;
        public string WteText { get; set; } = string.Empty;
        public bool IsValid { get; set; } = true;
        public string? Error { get; set; }
    }

    private async Task ToggleActive(int id)
    {
        var u = UserService.GetById(id);
        if (u == null) return;
        u.Active = !u.Active;
        UserService.UpdateUser(u);
        _users = UserService.GetAllUsers();
        await InvokeAsync(StateHasChanged);
    }

    private void SetSort(string col)
    {
        if (_sortColumn == col) _sortAsc = !_sortAsc; else { _sortColumn = col; _sortAsc = true; }
    }

    private string SortIcon(string col)
    {
        if (_sortColumn != col) return string.Empty;
        return _sortAsc ? " ▲" : " ▼";
    }
}
