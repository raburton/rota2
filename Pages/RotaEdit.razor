@page "/rotas/edit/{Id:int?}"
@using Rota2.Models
@inject IRotaService RotaService
@inject IUserService UserService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<h3>@(IsNew ? "Add Rota" : "Edit Rota")</h3>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert alert-info">@_message</div>
}

<EditForm Model="_model" OnValidSubmit="HandleSubmit">
    <InputText @bind-Value="_model.Name" class="form-control" placeholder="Rota name" />

    <h5 class="mt-3">Shifts</h5>
    <table class="table">
        <thead><tr><th>Day</th><th>Start</th><th>End</th><th></th></tr></thead>
        <tbody>
        @for(int i=0;i<_model.Shifts.Count;i++)
        {
            var idx = i;
            var shift = _model.Shifts[idx];
            <tr @key="shift">
                <td>
                    <InputSelect @bind-Value="shift.Day" class="form-control">
                        @foreach(var d in Enum.GetValues(typeof(DayOfWeek)).Cast<DayOfWeek>())
                        {
                            <option value="@d">@d</option>
                        }
                    </InputSelect>
                </td>
                <td><InputText @bind-Value="shift.StartText" class="form-control" placeholder="HH:MM" /></td>
                <td><InputText @bind-Value="shift.EndText" class="form-control" placeholder="HH:MM" /></td>
                <td><button class="btn btn-sm btn-danger" type="button" @onclick="(() => RemoveShift(idx))">Remove</button></td>
            </tr>
        }
        </tbody>
    </table>
    <button class="btn btn-secondary" type="button" @onclick="AddShift">Add Shift</button>

    <h5 class="mt-3">Doctors (Registrars or Consultants)</h5>
    @foreach(var u in _allUsers)
    {
        if (u.Role == UserRole.Registrar || u.Role == UserRole.Consultant)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" @onchange="@(e => ToggleDoctor(u.Id, (bool)((ChangeEventArgs)e).Value))" checked="@(_model.DoctorIds.Contains(u.Id))" />
                <label class="form-check-label">@u.Name (@u.Email)</label>
            </div>
        }
    }

    <h5 class="mt-3">Rota Admins</h5>
    @foreach(var u in _allUsers)
    {
        <div class="form-check">
            <input class="form-check-input" type="checkbox" @onchange="@(e => ToggleAdmin(u.Id, (bool)((ChangeEventArgs)e).Value))" checked="@(_model.AdminIds.Contains(u.Id))" />
            <label class="form-check-label">@u.Name (@u.Email)</label>
        </div>
    }

    <div class="mt-3">
        <button class="btn btn-primary" type="submit">Save</button>
        <button class="btn btn-secondary ms-2" type="button" @onclick="Cancel">Cancel</button>
    </div>
</EditForm>

@code {
    [Parameter]
    public int? Id { get; set; }

    private bool IsNew => !Id.HasValue;

    private RotaModel _model = new RotaModel();
    private string _message = string.Empty;
    private List<Rota2.Models.User> _allUsers = new List<Rota2.Models.User>();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        var isGlobal = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (isGlobal != true)
        {
            _message = "Not authorized.";
            return;
        }

        _allUsers = UserService.GetAllUsers().ToList();

        if (Id.HasValue)
        {
            var r = RotaService.GetById(Id.Value);
            if (r != null)
            {
                _model.Id = r.Id;
                _model.Name = r.Name;
                _model.Shifts = r.Shifts.Select(s => new ShiftModel { Day = s.Day, StartText = s.Start.ToString(@"hh\:mm"), EndText = s.End.ToString(@"hh\:mm") }).ToList();
                _model.DoctorIds = r.RotaDoctors.Select(rd => rd.UserId).ToList();
                _model.AdminIds = r.RotaAdmins.Select(ra => ra.UserId).ToList();
            }
        }
    }

    private void AddShift()
    {
        _model.Shifts.Add(new ShiftModel { Day = DayOfWeek.Monday, StartText = "09:00", EndText = "17:00" });
    }

    private void RemoveShift(int i)
    {
        if (i >= 0 && i < _model.Shifts.Count) _model.Shifts.RemoveAt(i);
    }

    private void ToggleDoctor(int userId, bool on)
    {
        if (on)
        {
            if (!_model.DoctorIds.Contains(userId)) _model.DoctorIds.Add(userId);
        }
        else
        {
            _model.DoctorIds.Remove(userId);
        }
    }

    private void ToggleAdmin(int userId, bool on)
    {
        if (on)
        {
            if (!_model.AdminIds.Contains(userId)) _model.AdminIds.Add(userId);
        }
        else
        {
            _model.AdminIds.Remove(userId);
        }
    }

    private void Cancel() => Nav.NavigateTo("/rotas");

    private void HandleSubmit()
    {
        // build rota entity
        var rota = new Rota { Id = _model.Id, Name = _model.Name };
        foreach (var s in _model.Shifts)
        {
            if (TimeSpan.TryParse(s.StartText, out var st) && TimeSpan.TryParse(s.EndText, out var et))
            {
                rota.Shifts.Add(new Shift { Day = s.Day, Start = st, End = et });
            }
        }

        if (IsNew)
        {
            RotaService.Create(rota, _model.DoctorIds, _model.AdminIds);
        }
        else
        {
            RotaService.Update(rota, _model.DoctorIds, _model.AdminIds);
        }
        Nav.NavigateTo("/rotas");
    }

    private class RotaModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public List<ShiftModel> Shifts { get; set; } = new List<ShiftModel>();
        public List<int> DoctorIds { get; set; } = new List<int>();
        public List<int> AdminIds { get; set; } = new List<int>();
    }

    private class ShiftModel
    {
        public DayOfWeek Day { get; set; }
        public string StartText { get; set; } = string.Empty;
        public string EndText { get; set; } = string.Empty;
    }
}
