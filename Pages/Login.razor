@page "/login"
@inject IUserService UserService
@inject NavigationManager Nav
@inject CustomAuthStateProvider AuthState

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-3">Login</h4>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleLogin">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="_model.Email" class="form-control" placeholder="Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="Password" />
                    </div>
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-primary" type="submit">Login</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new LoginModel();
    private string _error = string.Empty;

    private void HandleLogin()
    {
        var user = UserService.Authenticate(_model.Email, _model.Password);
        if (user == null)
        {
            _error = "Invalid credentials";
            return;
        }
        AuthState.MarkUserAsAuthenticated(user);
        Nav.NavigateTo("/");
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
