@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@inject IUserService UserService
@inject NavigationManager Nav
@inject CustomAuthStateProvider AuthState
@inject HttpClient Http

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title mb-3">Login</h4>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleLogin">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <InputText @bind-Value="_model.Email" class="form-control" placeholder="Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText @bind-Value="_model.Password" type="password" class="form-control" placeholder="Password" />
                    </div>
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-primary" type="submit">Login</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel _model = new LoginModel();
    private string _error = string.Empty;

    private string? _returnUrl;

    protected override void OnInitialized()
    {
        // parse returnUrl from query string if provided
        var uri = new Uri(Nav.Uri);
        var qs = uri.Query;
        if (!string.IsNullOrEmpty(qs))
        {
            var parsed = QueryHelpers.ParseQuery(qs);
            if (parsed.TryGetValue("returnUrl", out var rv)) _returnUrl = rv.ToString();
        }
    }

    private async Task HandleLogin()
    {
        var payload = new { Email = _model.Email, Password = _model.Password };
        var loginUri = new Uri(new Uri(Nav.BaseUri), "account/login");
        var resp = await Http.PostAsJsonAsync(loginUri, payload);
        if (!resp.IsSuccessStatusCode)
        {
            _error = "Invalid credentials";
            return;
        }
        // server issued signed auth cookie; update auth state for current circuit
        var user = await resp.Content.ReadFromJsonAsync<UserInfo>();
        if (user != null)
        {
            AuthState.MarkUserAsAuthenticated(new Rota2.Models.User { Id = user.Id, Name = user.Name, Email = user.Email, IsGlobalAdmin = user.IsGlobalAdmin, Role = Enum.Parse<Rota2.Models.UserRole>(user.Role) });
        }
        // navigate to returnUrl if provided and local, otherwise to dashboard
        if (!string.IsNullOrEmpty(_returnUrl) && IsLocalUrl(_returnUrl))
        {
            Nav.NavigateTo(_returnUrl);
        }
        else
        {
            Nav.NavigateTo("/dashboard");
        }
    }

    private bool IsLocalUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return false;
        // relative paths are allowed
        if (url.StartsWith("/")) return true;
        // absolute URIs are allowed only if same origin
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            try
            {
                var baseUri = new Uri(Nav.BaseUri);
                return uri.Scheme == baseUri.Scheme && uri.Host == baseUri.Host && uri.Port == baseUri.Port;
            }
            catch
            {
                return false;
            }
        }
        return false;
    }

    private class UserInfo { public int Id { get; set; } public string Name { get; set; } = string.Empty; public string Email { get; set; } = string.Empty; public bool IsGlobalAdmin { get; set; } public string Role { get; set; } = string.Empty; }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
