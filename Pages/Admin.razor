@page "/admin"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IRotaService RotaService

<h3>Admin Dashboard</h3>

<p>This is a minimal admin dashboard. Only global admins should see/manage resources.</p>

@if (!_isGlobalAdmin)
{
    <div class="alert alert-danger">You are not authorized to manage this area.</div>
}
else
{
    <div class="mb-3">
        <div class="btn-group" role="group">
            <ActionButton Icon="bi-calendar2-week" Text="@($"Manage Rotas ({_rotasCount ?? 0})")" Variant="btn-outline-secondary" Href="/rotas" />
            <ActionButton Icon="bi-people" Text="@($"Manage Users ({_usersCount ?? 0})")" Variant="btn-outline-secondary" Href="/users" />
            <ActionButton Icon="bi-diagram-3" Text="Shift Allocations" Variant="btn-outline-secondary" Href="/rotas/allocations" />
        </div>
    </div>
}

@code {
    private bool _isGlobalAdmin = false;
    private int? _rotasCount = null;
    private int? _usersCount = null;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (_isGlobalAdmin)
        {
            _rotasCount = RotaService.GetAll().Count();
            _usersCount = UserService.GetAllUsers().Count();
        }
    }
}
