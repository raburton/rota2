@page "/admin"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IRotaService RotaService

<h3>Admin Dashboard</h3>

<p>This is a minimal admin dashboard. Only global admins should see/manage resources.</p>

@if (!_isGlobalAdmin)
{
    <div class="alert alert-danger">You are not authorized to manage this area.</div>
}
else
{
    <div class="mb-3">
        <div class="btn-group" role="group">
            <a class="btn btn-outline-secondary" href="/rotas"><i class="bi bi-calendar2-week me-1"></i>Manage Rotas (@(_rotasCount ?? 0))</a>
            <a class="btn btn-outline-secondary" href="/users"><i class="bi bi-people me-1"></i>Manage Users (@(_usersCount ?? 0))</a>
            <a class="btn btn-outline-secondary" href="/rotas/allocations"><i class="bi bi-diagram-3 me-1"></i>Shift Allocations</a>
        </div>
    </div>
}

@code {
    private bool _isGlobalAdmin = false;
    private int? _rotasCount = null;
    private int? _usersCount = null;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;
        _isGlobalAdmin = user?.FindFirst(c => c.Type == "IsGlobalAdmin")?.Value == "True";
        if (_isGlobalAdmin)
        {
            _rotasCount = RotaService.GetAll().Count();
            _usersCount = UserService.GetAllUsers().Count();
        }
    }
}
